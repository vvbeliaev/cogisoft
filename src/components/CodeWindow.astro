---
/**
 * CodeWindow — Raycast-inspired window chrome for the hero.
 * See /DESIGN.md § Hero / code block.
 */
interface Props {
  title?: string;
}

const { title = "COGITO.SOFTWARE" } = Astro.props;

const lines = [
  {
    number: "01",
    tokens: [
      { text: "import", class: "text-accent" },
      { text: " { ", class: "text-foreground/70" },
      { text: "Agency", class: "text-primary" },
      { text: " } ", class: "text-foreground/70" },
      { text: "from", class: "text-accent" },
      { text: " '@cogito/core'", class: "text-[#24a148]" },
      { text: ";", class: "text-foreground/70" },
    ],
  },
  { number: "02", tokens: [] },
  {
    number: "03",
    tokens: [
      { text: "const", class: "text-accent" },
      { text: " product ", class: "text-foreground" },
      { text: "= ", class: "text-foreground/70" },
      { text: "new ", class: "text-accent" },
      { text: "Agency", class: "text-primary" },
      { text: ".Project({", class: "text-foreground/70" },
    ],
  },
  {
    number: "04",
    indent: true,
    tokens: [
      { text: "vision: ", class: "text-foreground/70" },
      { text: "'uncompromised'", class: "text-[#24a148]" },
      { text: ",", class: "text-foreground/70" },
    ],
  },
  {
    number: "05",
    indent: true,
    tokens: [
      { text: "velocity: ", class: "text-foreground/70" },
      { text: "'7_days'", class: "text-[#24a148]" },
      { text: ",", class: "text-foreground/70" },
    ],
  },
  {
    number: "06",
    indent: true,
    tokens: [
      { text: "ownership: ", class: "text-foreground/70" },
      { text: "true", class: "text-[#24a148]" },
    ],
  },
  {
    number: "07",
    tokens: [{ text: "});", class: "text-foreground/70" }],
  },
  { number: "08", tokens: [] },
  {
    number: "09",
    tokens: [
      { text: "product", class: "text-foreground" },
      { text: ".launch();", class: "text-foreground/70" },
    ],
  },
];
---

<div
  class="code-window surface-lift raised-whisper overflow-hidden relative group"
>
  <!-- Window chrome -->
  <div
    class="flex items-center gap-2 px-5 py-3 border-b"
    style="border-color: color-mix(in oklch, var(--foreground), transparent 90%);"
  >
    <div class="flex gap-1.5">
      <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
      <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
      <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
    </div>
    <div class="ml-auto label-mono">
      {title}
    </div>
  </div>

  <!-- Code area -->
  <div class="relative">
    <div class="font-mono text-[13px] leading-[1.7] py-6 relative z-10">
      {
        lines.map((line) => (
          <div class="grid grid-cols-[3rem_1fr] group/line">
            <span class="text-foreground/20 select-none tabular-nums text-right pr-5 py-0.5">
              {line.number}
            </span>
            <div
              class={`flex items-center whitespace-pre py-0.5 pr-6 ${line.indent ? "pl-6" : "pl-0"}`}
            >
              {line.tokens.length > 0 ? (
                line.tokens.map((token) => (
                  <span class={token.class}>{token.text}</span>
                ))
              ) : (
                <span class="h-5" />
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .code-window {
    border-radius: 12px;
  }
</style>
