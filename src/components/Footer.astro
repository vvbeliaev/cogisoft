---
const currentYear = new Date().getFullYear();
---

<footer class="mt-24">
  <div class="container mx-auto px-6 py-16">
    <div
      class="flex flex-col md:flex-row justify-between items-start md:items-end gap-10 pt-12"
      style="box-shadow: rgba(20, 20, 19, 0.08) 0 1px 0 0 inset;"
    >
      <div class="max-w-md">
        <a
          href="/"
          class="text-2xl"
          style="font-family: var(--font-display); font-weight: 500;"
          >Cogito Software</a
        >
        <p class="body-editorial mt-3">
          I don't build useless software. Local-first systems, repairable
          workflows, modular architecture.
        </p>
      </div>

      <nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
        <a
          href="/privacy-policy"
          class="text-foreground/60 hover:text-foreground transition-colors"
          >Privacy</a
        >
        <a
          href="/terms-and-conditions"
          class="text-foreground/60 hover:text-foreground transition-colors"
          >Terms</a
        >
        <a
          href="/contact"
          class="text-foreground/60 hover:text-foreground transition-colors"
          >Contact</a
        >
      </nav>

      <div class="label-mono">
        © {currentYear} / all systems nominal
      </div>
    </div>
  </div>
</footer>
