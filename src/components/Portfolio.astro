---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import SectionLabel from "$components/SectionLabel.astro";

const activeProjects = (await getCollection("labs")).filter(
  (p) => !p.data.deprecated
);
const featuredProject =
  activeProjects.find((p) => p.data.featured) ?? activeProjects[0];
const otherProjects = featuredProject
  ? activeProjects
      .filter((p) => p.id !== featuredProject.id)
      .sort((a, b) => a.data.priority - b.data.priority)
      .slice(0, 3)
  : [];
---

<div>
  <div class="mb-16 max-w-2xl">
    <SectionLabel index="01" text="shipped" />
    <h2 class="mt-6">Recent work</h2>
    <p class="body-editorial mt-6">
      Production-ready applications I've shipped. Check out some of my recent
      deployments.
    </p>
  </div>

  <div class="space-y-6">
    <!-- Featured Project -->
    {
      featuredProject && (
        <a
          href={featuredProject.data.link}
          target="_blank"
          rel="noopener noreferrer"
          class="group block surface-lift overflow-hidden transition-opacity hover:opacity-95"
        >
          <div class="flex flex-col lg:flex-row">
            <div class="lg:w-2/3 h-64 lg:h-96 overflow-hidden relative">
              {featuredProject.data.image && (
                <Image
                  src={featuredProject.data.image}
                  alt={featuredProject.data.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                />
              )}
            </div>

            <div class="lg:w-1/3 p-10 flex flex-col justify-center">
              <div class="label-accent mb-4">— featured project</div>
              <h3 class="text-2xl lg:text-3xl mb-4 group-hover:text-primary transition-colors">
                {featuredProject.data.title}
              </h3>
              <p class="body-editorial mb-8 text-[15px]">
                {featuredProject.data.description}
              </p>

              <div class="flex flex-wrap gap-2 mt-auto">
                {featuredProject.data.tags.map((tag) => (
                  <span
                    class="px-3 py-1 text-[11px] font-mono uppercase tracking-wider surface-lift"
                    style="border-radius: 4px;"
                  >
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </a>
      )
    }

    <!-- Other Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {
        otherProjects.map((project) => (
          <a
            href={project.data.link}
            target="_blank"
            rel="noopener noreferrer"
            class="group block surface-lift overflow-hidden transition-opacity hover:opacity-95"
          >
            <div class="h-48 overflow-hidden relative">
              {project.data.image && (
                <Image
                  src={project.data.image}
                  alt={project.data.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                />
              )}
            </div>

            <div class="p-6">
              <div class="label-mono mb-3 flex items-center gap-2">
                live deployment
                <Icon name="ph:arrow-up-right" class="w-3 h-3" />
              </div>
              <h3 class="text-xl mb-2 group-hover:text-primary transition-colors">
                {project.data.title}
              </h3>
              <p class="text-[14px] text-foreground/60 leading-relaxed line-clamp-2 mb-6">
                {project.data.description}
              </p>

              <div class="flex flex-wrap gap-1.5">
                {project.data.tags.map((tag) => (
                  <span
                    class="px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider text-foreground/60 surface-lift"
                    style="border-radius: 3px;"
                  >
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <div class="pt-8">
      <a
        href="/labs"
        class="inline-flex items-center justify-center gap-2 h-12 px-8 text-[14px] font-medium text-foreground transition-colors hover:bg-muted"
      >
        View all projects
      </a>
    </div>
  </div>
</div>
