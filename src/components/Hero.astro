---
import { Icon } from "astro-icon/components";
import SectionLabel from "$components/SectionLabel.astro";
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden pt-24 pb-16"
>
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-block mb-6">
        <SectionLabel text="rapid build / full ownership" accent />
      </div>

      <h1 class="mb-8">
        Turn your idea into a <br />
        <span class="text-primary">working product</span> in 7 days.
      </h1>

      <p class="body-editorial max-w-3xl mx-auto mb-12">
        A production-grade prototype you can self-host and extend. No lock-in,
        no subscriptions, no vague deliverables — just a working system you
        own.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href="#offer"
          class="inline-flex items-center justify-center gap-2 h-12 px-8 text-[15px] font-medium bg-primary text-primary-foreground transition-opacity hover:opacity-90"
        >
          Get Started
          <Icon name="ph:arrow-right" class="w-4 h-4 ml-1" />
        </a>
        <a
          href="#portfolio"
          class="inline-flex items-center justify-center gap-2 h-12 px-8 text-[15px] font-medium text-foreground transition-colors hover:bg-muted"
        >
          View Portfolio
        </a>
      </div>

      <!-- Stats -->
      <div
        class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-8 pt-10"
        style="box-shadow: rgba(20, 20, 19, 0.08) 0 1px 0 0 inset;"
      >
        {
          [
            { value: "7 Days", label: "Delivery window" },
            { value: "One-off", label: "No subscriptions" },
            { value: "100%", label: "Code Ownership" },
            { value: "Local", label: "Deploy anywhere" },
          ].map((stat) => (
            <div>
              <div
                class="text-3xl md:text-4xl text-primary mb-2"
                style="font-family: var(--font-display); font-weight: 500; letter-spacing: var(--tracking-display);"
              >
                {stat.value}
              </div>
              <div class="label-mono">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
