---
import { Icon } from "astro-icon/components";
import SectionLabel from "$components/SectionLabel.astro";

const items = [
  "Frontend PWA (Mobile Ready)",
  "Backend AI/LLM Integration",
  "Meilisearch (Fast Search)",
  "PocketBase (Auth + DB + Admin)",
  "Dedicated Server Deployment",
  "Stripe Integration (Payments)",
  "Posthog Integration (Analytics)",
  "SEO Optimized Structure",
];
---

<section id="offer" class="py-16 md:py-24 relative">
  <div class="container mx-auto px-6">
    <div class="max-w-5xl mx-auto surface-lift p-8 md:p-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Left: value -->
        <div class="flex flex-col justify-center">
          <SectionLabel text="deployment-grade prototype" accent />

          <h2 class="mt-6 mb-8">
            Fullstack prototype <br />
            <span class="text-primary">ready in 7 days.</span>
          </h2>
          <p class="body-editorial mb-10">
            Don't waste months building an MVP. I provide a complete,
            production-grade foundation to validate your "Job to be Done"
            hypothesis. Drive traffic, test conversions, and iterate fast.
          </p>

          <div class="flex items-baseline gap-4 mb-10">
            <span class="text-2xl text-foreground/30 line-through">$1000</span>
            <span
              class="text-5xl"
              style="font-family: var(--font-display); font-weight: 500; letter-spacing: var(--tracking-display);"
              >$499</span
            >
            <span class="label-accent self-center">early adopters</span>
          </div>

          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 w-full md:w-auto md:self-start h-12 px-10 text-[15px] font-medium bg-primary text-primary-foreground transition-opacity hover:opacity-90"
          >
            Start your project
          </a>
        </div>

        <!-- Right: includes -->
        <div
          class="border-l pl-8 lg:pl-10"
          style="border-color: color-mix(in oklch, var(--foreground), transparent 90%);"
        >
          <h3 class="mb-6">What's included</h3>
          <ul class="space-y-3">
            {
              items.map((item) => (
                <li class="flex items-center gap-3 text-[15px] text-foreground/80">
                  <Icon name="ph:check-bold" class="w-4 h-4 text-primary shrink-0" />
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
