---
import Root from "$layouts/Root.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import SectionLabel from "$components/SectionLabel.astro";

export const prerender = true;

const projects = await getCollection("labs");
const sortedProjects = projects.sort(
  (a, b) => a.data.priority - b.data.priority
);

const activeProjects = sortedProjects.filter((p) => !p.data.deprecated);
const featuredProjects = activeProjects.filter((p) => p.data.featured);
const regularProjects = activeProjects.filter((p) => !p.data.featured);
const deprecatedProjects = sortedProjects.filter((p) => p.data.deprecated);
---

<Root path="/labs" title="Labs | Cogito Software">
  <main class="pt-28 md:pt-40 pb-16 md:pb-24">
    <div class="container mx-auto px-6">
      <div class="mb-20 max-w-2xl">
        <SectionLabel index="00" text="workshop" accent />
        <h1 class="mt-6 mb-6">
          Cogito <span class="text-primary">Labs.</span>
        </h1>
        <p class="body-editorial">
          My experimental workshop where I build, test, and ship innovative
          products.
        </p>
      </div>

      {
        activeProjects.length > 0 ? (
          <div class="space-y-4">
            {/* Featured projects — full-width spotlight cards */}
            {featuredProjects.map((project) => (
              <a
                href={project.data.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col md:flex-row surface-lift overflow-hidden transition-opacity hover:opacity-95"
              >
                {/* Color gradient cover */}
                <div
                  class={`md:w-80 lg:w-96 shrink-0 h-56 md:h-auto relative bg-linear-to-br ${project.data.color} flex items-center justify-center overflow-hidden`}
                >
                  {project.data.image ? (
                    <Image
                      src={project.data.image}
                      alt={project.data.title}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                    />
                  ) : (
                    <div class="relative w-full h-full flex items-center justify-center">
                      {/* Decorative grid */}
                      <div
                        class="absolute inset-0 opacity-20"
                        style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 24px 24px;"
                      />
                      <span class="relative text-white/90 font-mono text-[11px] uppercase tracking-widest">
                        {project.data.title}
                      </span>
                    </div>
                  )}
                </div>

                <div class="p-8 flex flex-col justify-between flex-1">
                  <div>
                    <div class="label-mono mb-4 flex items-center gap-3">
                      <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-sm bg-primary/10 text-primary text-[10px] font-mono uppercase tracking-wider">
                        <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse" />
                        featured
                      </span>
                      <span class="text-foreground/40">live deployment</span>
                      <Icon name="ph:arrow-up-right" class="w-3 h-3 text-foreground/40" />
                    </div>
                    <h2 class="mb-3 group-hover:text-primary transition-colors">
                      {project.data.title}
                    </h2>
                    <p class="text-[15px] text-foreground/60 leading-relaxed max-w-xl">
                      {project.data.description}
                    </p>
                  </div>

                  <div class="flex flex-wrap gap-1.5 mt-6">
                    {project.data.tags.map((tag) => (
                      <span
                        class="px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider text-foreground/60 surface-lift"
                        style="border-radius: 3px;"
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              </a>
            ))}

            {/* Regular active projects */}
            {regularProjects.length > 0 && (
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 pt-2">
                {regularProjects.map((project) => (
                  <a
                    href={project.data.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group block surface-lift overflow-hidden transition-opacity hover:opacity-95"
                  >
                    <div
                      class={`h-48 overflow-hidden relative bg-linear-to-br ${project.data.color}`}
                    >
                      {project.data.image ? (
                        <Image
                          src={project.data.image}
                          alt={project.data.title}
                          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                        />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center">
                          <div
                            class="absolute inset-0 opacity-20"
                            style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 20px 20px;"
                          />
                          <span class="relative text-white/90 font-mono text-[10px] uppercase tracking-widest">
                            {project.data.title}
                          </span>
                        </div>
                      )}
                    </div>

                    <div class="p-6">
                      <div class="label-mono mb-3 flex items-center gap-2">
                        live deployment
                        <Icon name="ph:arrow-up-right" class="w-3 h-3" />
                      </div>
                      <h3 class="mb-3 group-hover:text-primary transition-colors">
                        {project.data.title}
                      </h3>
                      <p class="text-[14px] text-foreground/60 leading-relaxed mb-6">
                        {project.data.description}
                      </p>

                      <div class="flex flex-wrap gap-1.5">
                        {project.data.tags.map((tag) => (
                          <span
                            class="px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider text-foreground/60 surface-lift"
                            style="border-radius: 3px;"
                          >
                            {tag}
                          </span>
                        ))}
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            )}
          </div>
        ) : (
          <div class="surface-lift p-10 text-center text-foreground/60 max-w-2xl">
            <p class="text-[14px]">
              No active experiments right now — cooking up the next batch.
            </p>
          </div>
        )
      }

      {
        deprecatedProjects.length > 0 && (
          <details class="mt-16 group">
            <summary class="cursor-pointer list-none inline-flex items-center gap-3 px-4 py-3 surface-lift text-[12px] font-mono uppercase tracking-wider text-foreground/60 hover:text-foreground/90 transition-colors select-none">
              <span class="inline-block w-2 h-2 rounded-full bg-foreground/30" />
              <span>
                Show discontinued ({deprecatedProjects.length})
              </span>
              <span class="opacity-50 group-open:rotate-90 transition-transform">
                ›
              </span>
            </summary>

            <div class="mt-8 pt-8 border-t border-dashed border-foreground/15">
              <p class="text-[12px] font-mono uppercase tracking-wider text-foreground/40 mb-6">
                — archived experiments, no longer maintained
              </p>

              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {deprecatedProjects.map((project) => (
                  <article class="block surface-lift overflow-hidden opacity-60 grayscale">
                    <div class="p-6">
                      <div class="label-mono mb-3 text-foreground/40">
                        archived
                      </div>
                      <h3 class="mb-3 line-through decoration-foreground/30">
                        {project.data.title}
                      </h3>
                      <p class="text-[14px] text-foreground/50 leading-relaxed mb-6">
                        {project.data.description}
                      </p>

                      <div class="flex flex-wrap gap-1.5">
                        {project.data.tags.map((tag) => (
                          <span
                            class="px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider text-foreground/40 surface-lift"
                            style="border-radius: 3px;"
                          >
                            {tag}
                          </span>
                        ))}
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </details>
        )
      }
    </div>
  </main>
</Root>
