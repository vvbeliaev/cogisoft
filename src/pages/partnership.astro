---
import Root from "$layouts/Root.astro";
import SectionLabel from "$components/SectionLabel.astro";
import { Icon } from "astro-icon/components";

const reasons = [
  {
    title: "Speed",
    body: "I deliver prototypes in days, not months.",
  },
  {
    title: "Quality",
    body: "Modern stack (Astro, Svelte, Go/Node). No legacy code.",
  },
  {
    title: "Reliability",
    body: "I handle the tech, you handle the client relationship.",
  },
];
---

<Root path="/partnership" title="Partnership | Cogito Software">
  <main class="relative min-h-screen flex flex-col">
    <section class="grow flex items-center justify-center py-20 md:py-28">
      <div class="container mx-auto px-6 relative">
        <div class="max-w-4xl mx-auto text-center">
          <div class="inline-block mb-6">
            <SectionLabel text="partnership channel" accent />
          </div>

          <h1 class="mb-8">
            I build. <br />
            <span class="text-primary">You sell.</span>
          </h1>

          <p class="body-editorial mb-16 max-w-2xl mx-auto">
            Lightning-fast iterations. Reliable delivery. Partner with me to
            offer premium software development to your clients without the
            overhead.
          </p>

          <div class="surface-lift max-w-2xl mx-auto p-10 text-left mb-12">
            <h3 class="mb-8">Why partner with Cogisoft?</h3>
            <ul class="space-y-6">
              {
                reasons.map((reason) => (
                  <li class="flex items-start gap-4">
                    <Icon name="ph:check-bold" class="w-4 h-4 mt-1.5 text-primary shrink-0" />
                    <div>
                      <div class="font-semibold text-[15px] mb-1">
                        {reason.title}
                      </div>
                      <p class="text-[15px] text-foreground/60 leading-relaxed">
                        {reason.body}
                      </p>
                    </div>
                  </li>
                ))
              }
            </ul>
          </div>

          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 h-12 px-10 text-[15px] font-medium bg-primary text-primary-foreground transition-opacity hover:opacity-90"
          >
            Become a partner
            <Icon name="ph:arrow-right" class="w-4 h-4 ml-1" />
          </a>
        </div>
      </div>
    </section>
  </main>
</Root>
