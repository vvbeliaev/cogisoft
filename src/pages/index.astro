---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import AvatarVB from "$assets/images/bw-2.jpeg";

import Root from "$layouts/Root.astro";
import Portfolio from "$components/Portfolio.astro";
import SectionLabel from "$components/SectionLabel.astro";
import Kbd from "$components/Kbd.astro";
import HeroShader from "$components/HeroShader.svelte";

const competencies = [
  {
    icon: "ph:globe-duotone",
    title: "Web Applications",
    body: "Complex, responsive web apps built for scale and performance.",
  },
  {
    icon: "ph:terminal-window-duotone",
    title: "Backend Systems",
    body: "Robust Go & Node.js architectures designed for high throughput.",
  },
  {
    icon: "ph:file-code-duotone",
    title: "System Integration",
    body: "Unifying diverse systems into one cohesive, valuable product.",
  },
  {
    icon: "ph:brain-duotone",
    title: "AI & ML",
    body: "Integration of LLMs and self-hosted models for intelligent apps.",
  },
];
---

<Root path="/" title="Cogito Software | No Useless Software">
  <main class="relative min-h-screen flex flex-col">
    <!-- ═══════════════════════════════════════════════════════════════
         HERO — Parchment editorial × code-window device
         ═══════════════════════════════════════════════════════════════ -->
    <section class="relative pt-32 lg:pt-44 pb-16 lg:pb-28">
      <div class="container mx-auto px-6">
        <div
          class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center"
        >
          <div class="lg:col-span-7 relative animate-in">
            <SectionLabel index="00" text="thinking" accent />

            <h1 class="mt-6 mb-8">
              I build <br />
              <span class="text-primary">useful software.</span>
            </h1>

            <p class="body-editorial max-w-xl mb-10">
              I combine architectural purity with full code ownership to
              guarantee your technical freedom. No lock-in, no vague
              deliverables — just a working system you own.
            </p>

            <div class="flex flex-wrap gap-4 items-center">
              <a
                href="https://cal.com/vvbeliaev/30min"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 h-12 px-8 text-[15px] font-medium bg-primary text-primary-foreground transition-opacity hover:opacity-90"
              >
                Book a Call
                <Icon name="ph:arrow-right" class="w-4 h-4 ml-1" />
              </a>
              <a
                href="/contact"
                class="inline-flex items-center justify-center gap-2 h-12 px-8 text-[15px] font-medium text-foreground transition-colors hover:bg-muted"
              >
                Contact
              </a>
              <span
                class="hidden sm:inline-flex items-center gap-2 label-mono ml-2"
              >
                or press
                <Kbd label="⌘" />
                <Kbd label="K" />
              </span>
            </div>
          </div>

          <div class="lg:col-span-5 animate-in" style="animation-delay: 120ms;">
            <div class="surface-lift overflow-hidden relative" style="aspect-ratio: 4/5;">
              <!-- WebGL reveal shader: BW → oil-painting on mouse -->
              <HeroShader
                imageSrc={AvatarVB.src}
                class="absolute inset-0 w-full h-full"
                client:only="svelte"
              />
              <!-- Cursor hint label -->
              <div
                class="pointer-events-none absolute bottom-4 right-4 label-mono text-[11px] opacity-40 select-none"
                style="mix-blend-mode: difference; color: white;"
              >
                move cursor
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         PORTFOLIO
         ═══════════════════════════════════════════════════════════════ -->
    <section id="portfolio" class="py-16 md:py-24">
      <div class="container mx-auto px-6">
        <Portfolio />
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         COMPETENCIES
         ═══════════════════════════════════════════════════════════════ -->
    <section id="competencies" class="py-16 md:py-24">
      <div class="container mx-auto px-6">
        <div class="mb-16 max-w-2xl">
          <SectionLabel index="02" text="building" />
          <h2 class="mt-6">Core competencies</h2>
          <p class="body-editorial mt-6">
            Four disciplines I ship end-to-end so you don't have to stitch
            together half a dozen vendors.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          {
            competencies.map((item) => (
              <div class="surface-lift p-8 transition-opacity hover:opacity-80">
                <div class="text-primary mb-6">
                  <Icon name={item.icon} class="w-8 h-8" />
                </div>
                <h3 class="mb-3">{item.title}</h3>
                <p class="text-[15px] text-foreground/60 leading-relaxed">
                  {item.body}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         OFFERING — Custom Solution
         ═══════════════════════════════════════════════════════════════ -->
    <section id="offerings" class="py-16 md:py-24">
      <div class="container mx-auto px-6">
        <div class="mb-16 max-w-2xl">
          <SectionLabel index="03" text="offering" />
          <h2 class="mt-6">My primary offering</h2>
        </div>

        <div class="max-w-5xl">
          <a
            href="/custom-solution"
            class="group block surface-lift p-10 md:p-14 transition-opacity hover:opacity-90"
          >
            <div class="flex flex-col md:flex-row gap-10 items-start">
              <div
                class="inline-flex p-5 text-primary surface-lift shrink-0"
                style="border-radius: 0;"
              >
                <Icon name="ph:rocket-launch-duotone" class="w-10 h-10" />
              </div>
              <div class="flex-1">
                <h3
                  class="text-3xl md:text-4xl mb-4"
                  style="font-family: var(--font-display); font-weight: 500; letter-spacing: var(--tracking-section);"
                >
                  Custom Solution
                </h3>
                <p class="text-lg text-primary mb-6">
                  Deployment-ready prototype in 7 days.
                </p>
                <p class="body-editorial mb-8 max-w-2xl">
                  I specialize in rapid, high-quality builds. You get a
                  production-grade foundation with full code ownership and no
                  vendor lock-in — perfect for validating new product concepts
                  or scaling existing ones.
                </p>
                <span
                  class="inline-flex items-center gap-2 text-[14px] font-semibold text-primary group-hover:gap-3 transition-all"
                >
                  Explore solution
                  <Icon name="ph:arrow-right" class="w-4 h-4 ml-1" />
                </span>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>
  </main>
</Root>
