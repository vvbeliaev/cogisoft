---
import { Icon } from "astro-icon/components";
import AvatarVB from "$assets/images/bw-2.jpeg";

import Root from "$layouts/Root.astro";
import Portfolio from "$components/Portfolio.astro";
import SectionLabel from "$components/SectionLabel.astro";
import Kbd from "$components/Kbd.astro";
import HeroShader from "$components/HeroShader.svelte";

import me from "../data/me.json";

const topSkills = [
  "Full Stack", "AI / LLM", "RAG", "Product", "DevOps", "Analytics",
];

const work = [
  {
    company: "SpaceNPlace",
    role: "AI Engineer",
    period: "Jan 2026 — Present",
    summary: "Building an AI-powered real estate intelligence platform with semantic property search and personalised scoring across 45+ cities.",
    highlights: ["Semantic search matching properties to lifestyle, not just checklist", "LLM-driven personalised scoring engine", "SvelteKit frontend + FastAPI backend"],
    stack: "SvelteKit · FastAPI · LLM · Postgres",
    current: true,
    link: "https://spacenplace.ai",
  },
  {
    company: "LLMAgent.ru",
    role: "Lead Developer & Product Dev",
    period: "Jan 2023 — Nov 2024",
    summary: "Led development of a self-hosted RAG system for enterprise clients, integrated with Bitrix24.",
    highlights: ["Vector search with Qdrant & Elasticsearch", "High-load FastAPI backend (concurrent sessions)", "Document ingestion pipelines with RBAC"],
    stack: "FastAPI · Qdrant · Elastic · Postgres · Docker",
    current: false,
    link: "https://llmagent.ru",
  },
  {
    company: "B2B Food Distribution",
    role: "Business Analyst",
    period: "Feb 2022 — Jan 2023",
    summary: "Analyzed operations and built financial / operational models for inventory and supply chain.",
    highlights: ["Demand forecasting & inventory management models", "Automated reporting — 60%+ manual work eliminated"],
    stack: "SQL · Python · Pandas",
    current: false,
    link: null,
  },
];

const cogito = {
  company: "Cogito Software",
  role: "Founder",
  period: "Nov 2024 — Present",
  link: "https://cogisoft.dev",
  projects: [
    { title: "Quizbee.academy", link: "https://quizbee.academy" },
    { title: "HackSeeker", link: "https://hackseeker.com" },
    { title: "YouStory.nl", link: "https://youstory.cogisoft.dev" },
    { title: "SpaceNPlace", link: "https://spacenplace.ai" },
  ],
};

const competencies = [
  {
    icon: "ph:globe-duotone",
    title: "Web Applications",
    body: "Complex, responsive web apps built for scale and performance.",
  },
  {
    icon: "ph:terminal-window-duotone",
    title: "Backend Systems",
    body: "Robust Go & Node.js architectures designed for high throughput.",
  },
  {
    icon: "ph:file-code-duotone",
    title: "System Integration",
    body: "Unifying diverse systems into one cohesive, valuable product.",
  },
  {
    icon: "ph:brain-duotone",
    title: "AI & ML",
    body: "Integration of LLMs and self-hosted models for intelligent apps.",
  },
];

const cvLinks = [
  { label: "AI Full Stack", href: "/cv/full-stack.pdf" },
  { label: "DevOps", href: "/cv/devops.pdf" },
  { label: "Analyst", href: "/cv/analyst.pdf" },
  { label: "TPM", href: "/cv/tpm.pdf" },
];
---

<Root path="/" title="Cogito Software | No Useless Software">
  <main class="relative min-h-screen flex flex-col">

    <!-- ═══════════════════════════════════════════════════════════════
         HERO
         ═══════════════════════════════════════════════════════════════ -->
    <section class="relative pt-32 lg:pt-44 pb-16 lg:pb-28">
      <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

          <!-- LEFT -->
          <div class="lg:col-span-7 relative animate-in">
            <SectionLabel index="00" text="thinking" accent />

            <p class="mt-6 mb-3 label-mono text-foreground/50 text-[13px] tracking-widest uppercase">
              Vladimir Beliaev
            </p>

            <h1 class="mb-6">
              I build <br />
              <span class="text-primary">useful software.</span>
            </h1>

            <p class="body-editorial max-w-lg mb-8 text-foreground/70">
              4+ years building AI-driven products — from enterprise RAG systems to micro-SaaS.
              Founder of Cogito Software.
            </p>

            <!-- top skills -->
            <div class="flex flex-wrap gap-2 mb-8">
              {topSkills.map((skill) => (
                <span class="label-mono text-[11px] px-2.5 py-1 border border-border text-foreground/50 hover:border-primary hover:text-primary transition-colors">
                  {skill}
                </span>
              ))}
            </div>

            <!-- social links -->
            <div class="flex items-center gap-5 mb-8">
              <a
                href={me.contacts.github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 label-mono text-[12px] text-foreground/50 hover:text-primary transition-colors"
              >
                <Icon name="ph:github-logo-fill" class="w-4 h-4" />
                GitHub
              </a>
              <a
                href={`https://t.me/${me.contacts.telegram.replace('@', '')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 label-mono text-[12px] text-foreground/50 hover:text-primary transition-colors"
              >
                <Icon name="ph:telegram-logo-fill" class="w-4 h-4" />
                Telegram
              </a>
              <a
                href={`mailto:${me.contacts.email}`}
                class="inline-flex items-center gap-2 label-mono text-[12px] text-foreground/50 hover:text-primary transition-colors"
              >
                <Icon name="ph:envelope-duotone" class="w-4 h-4" />
                Email
              </a>
            </div>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-4 items-center">
              <a
                href="https://cal.com/vvbeliaev/30min"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 h-12 px-8 text-[15px] font-medium bg-primary text-primary-foreground transition-opacity hover:opacity-90"
              >
                Book a Call
                <Icon name="ph:arrow-right" class="w-4 h-4 ml-1" />
              </a>

              <!-- CV dropdown -->
              <div class="relative group">
                <button
                  class="inline-flex items-center justify-center gap-2 h-12 px-6 text-[14px] font-medium border border-border text-foreground hover:border-primary hover:text-primary transition-colors"
                >
                  <Icon name="ph:file-arrow-down-duotone" class="w-4 h-4" />
                  Download CV
                  <Icon name="ph:caret-down" class="w-3 h-3 ml-1" />
                </button>
                <div class="absolute left-0 top-full mt-1 z-50 min-w-[200px] border border-border bg-background shadow-lg opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-opacity">
                  {cvLinks.map((cv) => (
                    <a
                      href={cv.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      download
                      class="flex items-center gap-3 px-4 py-2.5 label-mono text-[12px] text-foreground/60 hover:text-primary hover:bg-muted transition-colors"
                    >
                      <Icon name="ph:file-pdf-duotone" class="w-3.5 h-3.5 shrink-0 text-primary" />
                      {cv.label}
                    </a>
                  ))}
                </div>
              </div>

              <span class="hidden sm:inline-flex items-center gap-2 label-mono ml-2">
                or press
                <Kbd label="⌘" />
                <Kbd label="K" />
              </span>
            </div>
          </div>

          <!-- RIGHT: shader photo -->
          <div class="lg:col-span-5 animate-in" style="animation-delay: 120ms;">
            <div class="surface-lift overflow-hidden relative" style="aspect-ratio: 4/5; max-width: 360px; margin: 0 auto;">
              <HeroShader
                imageSrc={AvatarVB.src}
                class="absolute inset-0 w-full h-full"
                client:only="svelte"
              />
              <div
                class="pointer-events-none absolute bottom-4 right-4 label-mono text-[11px] opacity-40 select-none"
                style="mix-blend-mode: difference; color: white;"
              >
                move cursor
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         PORTFOLIO
         ═══════════════════════════════════════════════════════════════ -->
    <section id="portfolio" class="py-16 md:py-24">
      <div class="container mx-auto px-6">
        <Portfolio />
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         WORK EXPERIENCE
         ═══════════════════════════════════════════════════════════════ -->
    <section id="experience" class="py-16 md:py-24">
      <div class="container mx-auto px-6">
        <div class="mb-16 max-w-2xl">
          <SectionLabel index="02" text="journey" />
          <h2 class="mt-6">Experience</h2>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">

          <!-- main timeline -->
          <div class="lg:col-span-8 space-y-0">
            {work.map((job, i) => (
              <div class="group relative flex gap-6 md:gap-8 pb-12 last:pb-0">
                <div class="flex flex-col items-center">
                  <div class={`w-2.5 h-2.5 rounded-full border-2 mt-1.5 shrink-0 transition-colors ${job.current ? 'border-primary bg-primary' : 'border-border bg-background group-hover:border-primary'}`} />
                  {i < work.length - 1 && (
                    <div class="w-px flex-1 mt-2 bg-border group-hover:bg-primary/20 transition-colors" />
                  )}
                </div>

                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-2">
                    {job.link ? (
                      <a href={job.link} target="_blank" rel="noopener noreferrer" class="text-[18px] font-medium hover:text-primary transition-colors">
                        {job.company}
                      </a>
                    ) : (
                      <span class="text-[18px] font-medium">{job.company}</span>
                    )}
                    {job.current && (
                      <span class="label-mono text-[10px] px-2 py-0.5 bg-primary/10 text-primary border border-primary/20">
                        current
                      </span>
                    )}
                    <span class="label-mono text-[12px] text-foreground/40 ml-auto">{job.period}</span>
                  </div>
                  <p class="label-accent text-[13px] mb-3">{job.role}</p>
                  <p class="text-[14px] text-foreground/60 leading-relaxed mb-4">{job.summary}</p>
                  <ul class="space-y-1.5 mb-4">
                    {job.highlights.map((h) => (
                      <li class="flex items-start gap-2.5 text-[13px] text-foreground/55 leading-relaxed">
                        <span class="w-1 h-1 rounded-full bg-primary mt-1.5 shrink-0" />
                        {h}
                      </li>
                    ))}
                  </ul>
                  <p class="label-mono text-[11px] text-foreground/35">{job.stack}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- Cogito sidebar -->
          <div class="lg:col-span-4">
            <div class="surface-lift p-6 border-l-2 border-primary/30 sticky top-28">
              <p class="label-mono text-[10px] text-foreground/35 mb-4 uppercase tracking-widest">parallel</p>
              <a
                href={cogito.link}
                target="_blank"
                rel="noopener noreferrer"
                class="text-[16px] font-medium hover:text-primary transition-colors block mb-1"
              >
                {cogito.company}
              </a>
              <p class="label-accent text-[12px] mb-1">{cogito.role}</p>
              <p class="label-mono text-[11px] text-foreground/40 mb-5">{cogito.period}</p>
              <ul class="space-y-2">
                {cogito.projects.map((p) => (
                  <li>
                    <a
                      href={p.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 text-[13px] text-foreground/55 hover:text-primary transition-colors"
                    >
                      <span class="w-1 h-1 rounded-full bg-primary/50 shrink-0" />
                      {p.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         COMPETENCIES
         ═══════════════════════════════════════════════════════════════ -->
    <section id="competencies" class="py-16 md:py-24">
      <div class="container mx-auto px-6">
        <div class="mb-16 max-w-2xl">
          <SectionLabel index="03" text="building" />
          <h2 class="mt-6">Core competencies</h2>
          <p class="body-editorial mt-6">
            Four disciplines I ship end-to-end so you don't have to stitch
            together half a dozen vendors.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          {
            competencies.map((item) => (
              <div class="surface-lift p-8 transition-opacity hover:opacity-80">
                <div class="text-primary mb-6">
                  <Icon name={item.icon} class="w-8 h-8" />
                </div>
                <h3 class="mb-3">{item.title}</h3>
                <p class="text-[15px] text-foreground/60 leading-relaxed">
                  {item.body}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

  </main>
</Root>
