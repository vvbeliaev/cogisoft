---
import Root from "$layouts/Root.astro";
import Hero from "$components/Hero.astro";
import TechStack from "$components/TechStack.astro";
import Offer from "$components/Offer.astro";
import SectionLabel from "$components/SectionLabel.astro";
import { Icon } from "astro-icon/components";

const beyondItems = [
  {
    icon: "ph:graph-duotone",
    title: "Complex integrations",
    body: "I handle deep architectural integrations with legacy systems, third-party APIs, and hardware interfaces. No system is too isolated to connect.",
  },
  {
    icon: "ph:stack-duotone",
    title: "Enterprise scaling",
    body: "Ready for the long haul. I support multi-year projects, infrastructure migrations, and building out complete engineering foundations for your product.",
  },
];
---

<Root path="/custom-solution" title="Custom Solution | Cogito Software">
  <main class="relative min-h-screen">
    <Hero />
    <TechStack />
    <Offer />

    <!-- Beyond the MVP -->
    <section class="py-16 md:py-24">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto">
          <div class="mb-16 text-center">
            <SectionLabel text="beyond mvp" />
            <h2 class="mt-6 mb-6">Beyond the MVP.</h2>
            <p class="body-editorial max-w-2xl mx-auto">
              While the 7-day sprint is the perfect start, I am fully
              equipped for long-term engineering challenges.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {
              beyondItems.map((item) => (
                <div class="surface-lift p-10">
                  <div class="text-primary mb-6">
                    <Icon name={item.icon} class="w-8 h-8" />
                  </div>
                  <h3 class="mb-4">{item.title}</h3>
                  <p class="text-[15px] text-foreground/60 leading-relaxed">
                    {item.body}
                  </p>
                </div>
              ))
            }
          </div>

          <div class="mt-12 p-10 surface-lift text-center">
            <h3 class="mb-4">Have a non-standard request?</h3>
            <p class="body-editorial max-w-2xl mx-auto mb-8">
              I'm ready to discuss absolutely any integrations, long-term
              partnerships, or unique technical constraints. My engineering
              expertise knows no bounds.
            </p>
            <a
              href="/contact"
              class="inline-flex items-center justify-center gap-2 h-12 px-10 text-[15px] font-medium bg-primary text-primary-foreground transition-opacity hover:opacity-90"
            >
              Discuss custom project
              <Icon name="ph:arrow-right" class="w-4 h-4 ml-1" />
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Root>
