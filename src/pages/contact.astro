---
import { Icon } from "astro-icon/components";

import Root from "$layouts/Root.astro";
import ContactForm from "$components/ContactForm.svelte";
import SectionLabel from "$components/SectionLabel.astro";
---

<Root path="/contact" title="Contact me | Cogito Software">
  <main class="pt-28 md:pt-40 pb-24 min-h-screen">
    <div class="container mx-auto px-6 max-w-5xl">

      <!-- Page header -->
      <div class="mb-10 md:mb-14 max-w-2xl">
        <SectionLabel index="00" text="get in touch" accent />
        <h2 class="mt-4">
          Let's build something
          <span class="text-primary">you truly own.</span>
        </h2>
      </div>

      <!-- Two-column layout -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.5fr] gap-16 lg:gap-24 items-start">

        <!-- Left: Info -->
        <div class="lg:sticky lg:top-32">
          <p class="body-editorial mb-10">
            Whether you're shipping a product or hardening your
            infrastructure, I build systems that stay useful offline,
            maintainable for years, and never lock you in.
          </p>

          <!-- Email -->
          <a
            href="mailto:contact@cogisoft.dev"
            class="group flex items-center gap-3 py-4 border-y border-border hover:opacity-70 transition-opacity"
          >
            <div class="w-9 h-9 flex items-center justify-center text-primary shrink-0 surface-lift">
              <Icon name="ph:envelope-duotone" class="w-4 h-4" />
            </div>
            <div>
              <div class="label-mono mb-0.5">email</div>
              <div class="text-[15px] font-medium">contact@cogisoft.dev</div>
            </div>
            <Icon
              name="ph:arrow-up-right"
              class="w-4 h-4 ml-auto text-foreground/25 group-hover:text-primary transition-colors"
            />
          </a>

          <!-- Book a call -->
          <a
            href="https://cal.com/vvbeliaev/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="group mt-4 flex items-center gap-3 h-11 px-4 w-full text-[13px] font-medium transition-colors surface-lift hover:bg-muted"
          >
            <Icon name="ph:calendar-duotone" class="w-4 h-4 text-primary" />
            Schedule a 30-min call
            <Icon
              name="ph:arrow-up-right"
              class="w-3.5 h-3.5 ml-auto text-foreground/30 group-hover:text-foreground/60 transition-colors"
            />
          </a>

          <p class="mt-8 text-xs text-foreground/35 font-mono">
            Replies within 24 h on business days.
          </p>
        </div>

        <!-- Right: Form panel with clean border + top terracotta accent -->
        <div class="ring-border" style="border-top: 2px solid var(--cg-terracotta);">
          <div class="p-8 md:p-10">
            <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-8 pb-8 border-b border-border">
              <div>
                <div class="label-mono mb-1.5">— send a message</div>
                <h2 class="text-xl mt-1">Tell me about the project.</h2>
              </div>
            </div>
            <ContactForm client:load />
          </div>
        </div>

      </div>
    </div>
  </main>
</Root>
