---
import Root from "$layouts/Root.astro";
import AboutUs from "$components/AboutUs.astro";
import SectionLabel from "$components/SectionLabel.astro";
import { Icon } from "astro-icon/components";
---

<Root path="/about" title="About Us | Cogito Software">
  <main class="relative min-h-screen pt-28 md:pt-40 pb-16 md:pb-24">
    <div class="container mx-auto px-6 mb-16">
      <a
        href="/"
        class="inline-flex items-center gap-2 label-mono hover:text-foreground transition-colors mb-10 group"
      >
        <Icon
          name="ph:arrow-left"
          class="w-3 h-3 group-hover:-translate-x-1 transition-transform"
        />
        back to home
      </a>

      <SectionLabel index="00" text="who we are" accent />
      <h1 class="mt-6 mb-6">Our team.</h1>
      <p class="body-editorial max-w-2xl">
        We are a small team of engineers and product builders dedicated to
        creating high-utility software that matters.
      </p>
    </div>

    <AboutUs />

    <div class="container mx-auto px-6 mt-24">
      <div class="max-w-3xl mx-auto text-center surface-lift p-12 md:p-16">
        <SectionLabel text="philosophy" />
        <h2 class="mt-6 mb-8">Our philosophy.</h2>
        <p class="body-editorial max-w-2xl mx-auto mb-10">
          We believe that software should be a tool for empowerment, not a
          source of dependency. That's why we prioritize full code ownership,
          local-first architectures, and extreme transparency in every project
          we undertake.
        </p>
        <div class="flex flex-col md:flex-row justify-center gap-3">
          {
            [
              "No Vendor Lock-in",
              "Pure Architecture",
              "Rapid Delivery",
            ].map((tag) => (
              <span
                class="px-5 py-2.5 label-mono surface-lift"
                style="border-radius: 0;"
              >
                {tag}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </main>
</Root>
