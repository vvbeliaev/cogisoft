---
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

import Root from "$layouts/Root.astro";
import WaitlistForm from "$components/WaitlistForm.svelte";
import SectionLabel from "$components/SectionLabel.astro";

export const prerender = true;

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPost = posts[0];
const remainingPosts = posts.slice(1);

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
};
---

<Root title="Blog | Cogito Software" path="/blog">
  <main class="pt-28 md:pt-40 pb-16 md:pb-24">
    <div class="container mx-auto px-6 max-w-6xl">
      <!-- Header -->
      <header class="mb-20 max-w-2xl">
        <SectionLabel index="00" text="engineering & philosophy journal" accent />
        <h1 class="mt-6">Thoughts<br /><span class="text-primary">& insights.</span></h1>
      </header>

      {
        featuredPost && (
          <section class="mb-24">
            <a
              href={`/blog/${featuredPost.id}`}
              class="group block surface-lift overflow-hidden transition-opacity hover:opacity-95"
            >
              <div class="grid lg:grid-cols-2 gap-0 items-stretch">
                <div class="p-10 md:p-14 lg:p-16 order-2 lg:order-1 flex flex-col justify-center">
                  <div class="flex items-center gap-4 mb-8">
                    <span class="label-accent">— featured</span>
                    <time class="label-mono">
                      {formatDate(featuredPost.data.pubDate)}
                    </time>
                  </div>
                  <h2 class="mb-6 group-hover:text-primary transition-colors">
                    {featuredPost.data.title}
                  </h2>
                  <p class="body-editorial mb-10 line-clamp-3">
                    {featuredPost.data.description}
                  </p>
                  <div class="flex items-center gap-2 text-[14px] font-semibold group-hover:gap-3 transition-all">
                    Read article
                    <Icon name="ph:arrow-right" class="w-4 h-4 text-primary" />
                  </div>
                </div>
                <div class="relative aspect-video lg:aspect-auto overflow-hidden order-1 lg:order-2">
                  {featuredPost.data.image && (
                    <Image
                      src={featuredPost.data.image}
                      alt={featuredPost.data.title}
                      width={2000}
                      height={2000}
                      loading="eager"
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                    />
                  )}
                </div>
              </div>
            </a>
          </section>
        )
      }

      <!-- Post Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          remainingPosts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex flex-col h-full surface-lift overflow-hidden transition-opacity hover:opacity-95"
            >
              <div class="aspect-video overflow-hidden">
                {post.data.image && (
                  <Image
                    src={post.data.image}
                    alt={post.data.title}
                    width={600}
                    height={400}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                  />
                )}
              </div>
              <div class="p-8 flex flex-col flex-1">
                <time class="label-mono mb-4">
                  {formatDate(post.data.pubDate)}
                </time>
                <h3 class="mb-4 group-hover:text-primary transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-[14px] text-foreground/60 line-clamp-2 leading-relaxed flex-1 mb-8">
                  {post.data.description}
                </p>
                <div class="flex items-center justify-between pt-6"
                     style="box-shadow: rgba(20,20,19,0.08) 0 1px 0 0 inset;">
                  <span class="label-mono">read full story</span>
                  <Icon name="ph:arrow-right" class="w-4 h-4 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all text-primary" />
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <!-- Newsletter -->
      <section class="mt-32 pt-20 text-center"
               style="box-shadow: rgba(20,20,19,0.08) 0 1px 0 0 inset;">
        <div class="max-w-2xl mx-auto">
          <SectionLabel text="stay updated" accent />
          <h2 class="mt-6 mb-6">
            Join my <span class="text-primary">digest.</span>
          </h2>
          <p class="body-editorial mb-12">
            Get the latest insights on software engineering, product design,
            and tech strategy delivered directly to your inbox.
          </p>
          <div class="max-w-md mx-auto">
            <WaitlistForm
              client:load
              experiment="cogisoft-newsletter"
              intent="newsletter-hub"
              buttonLabel="Subscribe"
              placeholder="Enter your email"
              subtext="No spam. Just engineering excellence."
              accented={false}
            />
          </div>
        </div>
      </section>
    </div>
  </main>
</Root>
