---
import "$styles/global.css";
import Header from "$components/Header.svelte";
import Footer from "$components/Footer.astro";
import Background from "$components/Background.astro";
import MetaPixelCode from "$components/MetaPixelCode.astro";
import Posthog from "$components/Posthog.astro";
import CommandPalette from "$components/CommandPalette.svelte";
import { ClientRouter } from "astro:transitions";

interface Props {
  path?: string;
  title?: string;
}

const { path = "/", title = "Cogito Software" }: Props = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon-32x32.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <script is:inline>
      const theme = localStorage.getItem("theme") || "LIGHT";
      document.documentElement.setAttribute("data-theme", theme);
    </script>

    <ClientRouter />
    <Posthog />
    <MetaPixelCode />
  </head>
  <body
    class="min-h-screen overflow-x-hidden bg-background text-foreground antialiased"
  >
    <Background transition:persist="background" />
    <Header path={path} client:only="svelte" transition:persist="header" />
    <slot />
    <Footer transition:persist="footer" />
    <CommandPalette client:only="svelte" />
  </body>
</html>
